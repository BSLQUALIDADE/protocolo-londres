<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Protocolo de Londres</title>
    <link rel="stylesheet" href="shared-styles.css">
    <link rel="stylesheet" href="extra-styles.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: linear-gradient(135deg, var(--color-primary, #0d6e6e) 0%, var(--color-primary-dark, #0a4f4f) 100%);
        }
        .login-card {
            background: white;
            border-radius: 14px;
            box-shadow: var(--shadow-lg, 0 10px 40px rgba(0,0,0,0.2));
            padding: 40px;
            width: 100%;
            max-width: 380px;
        }
        .login-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }
        .login-logo-icon {
            width: 38px; height: 38px;
            background: var(--color-primary, #0d6e6e);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 18px;
        }
        .login-title { font-size: 20px; font-weight: 700; color: var(--color-text-primary, #1a1a1a); }
        .login-subtitle { font-size: 13px; color: var(--color-text-secondary, #666); margin-bottom: 28px; }
        .login-field { margin-bottom: 16px; }
        .login-field label { display: block; font-size: 13px; font-weight: 600; color: var(--color-text-primary, #1a1a1a); margin-bottom: 6px; }
        .login-field input {
            width: 100%; padding: 11px 14px; border: 1px solid var(--color-border, #ddd);
            border-radius: 8px; font-size: 14px; box-sizing: border-box;
        }
        .login-field input:focus { outline: none; border-color: var(--color-primary, #0d6e6e); }
        .login-btn {
            width: 100%; padding: 12px; background: var(--color-primary, #0d6e6e); color: white;
            border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer;
            margin-top: 8px; transition: opacity 0.2s;
        }
        .login-btn:hover { opacity: 0.9; }
        .login-btn:disabled { opacity: 0.6; cursor: not-allowed; }
        .login-error {
            background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c;
            padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; display: none;
        }
        .login-error.show { display: block; }
        .login-footer { text-align: center; font-size: 11px; color: var(--color-text-tertiary, #999); margin-top: 24px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-icon">🏥</div>
            <div class="login-title">Protocolo de Londres</div>
        </div>
        <div class="login-subtitle">BSL Saúde — Sistema de Qualidade e Segurança do Paciente</div>

        <div class="login-error" id="loginError"></div>

        <form id="loginForm">
            <div class="login-field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required autocomplete="username" placeholder="seu.email@bslsaude.com">
            </div>
            <div class="login-field">
                <label for="senha">Senha</label>
                <input type="password" id="senha" name="senha" required autocomplete="current-password" placeholder="••••••••">
            </div>
            <button type="submit" class="login-btn" id="btnLogin">Entrar</button>
        </form>

        <div class="login-footer">Acesso restrito à equipe de qualidade BSL Saúde</div>
    </div>

    <script>
        // Se já existe uma sessão válida, vai direto pro dashboard
        (function checkExistingSession() {
            const token = localStorage.getItem('auth-token');
            if (token) {
                window.location.href = 'novo-protocolo.html';
            }
        })();

        const form = document.getElementById('loginForm');
        const errorBox = document.getElementById('loginError');
        const btnLogin = document.getElementById('btnLogin');

        function mostrarErro(mensagem) {
            errorBox.textContent = mensagem;
            errorBox.classList.add('show');
        }

        function esconderErro() {
            errorBox.classList.remove('show');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            esconderErro();

            const email = document.getElementById('email').value.trim();
            const senha = document.getElementById('senha').value;

            btnLogin.disabled = true;
            btnLogin.textContent = 'Entrando...';

            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, senha })
                });

                const json = await response.json();

                if (response.ok && json.sucesso) {
                    // Guarda o token de sessão e os dados do usuário logado.
                    // O token será enviado como "Authorization: Bearer <token>"
                    // em chamadas futuras que exijam autenticação.
                    localStorage.setItem('auth-token', json.access_token);
                    localStorage.setItem('auth-refresh-token', json.refresh_token);
                    localStorage.setItem('usuario-logado', JSON.stringify(json.usuario));

                    window.location.href = 'novo-protocolo.html';
                } else {
                    mostrarErro(json.mensagem || 'Email ou senha incorretos.');
                    btnLogin.disabled = false;
                    btnLogin.textContent = 'Entrar';
                }
            } catch (err) {
                mostrarErro('Não foi possível conectar ao servidor. Verifique sua conexão e tente novamente.');
                btnLogin.disabled = false;
                btnLogin.textContent = 'Entrar';
            }
        });
    </script>
</body>
</html>
